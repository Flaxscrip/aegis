# AEGIS NODE B — env for the second (validation) node. Real file gitignored; see nodeb.env.example.
ARCHON_UID=502
ARCHON_GID=20
ARCHON_ADMIN_API_KEY=<openssl rand -hex 32>
ARCHON_ENCRYPTED_PASSPHRASE=<openssl rand -hex 16>
# Peer link: node B forwards unresolvable DIDs to node A's gatekeeper (on the shared aegis-peer net).
NODEB_FALLBACK_URL=http://gatekeeper:4224
# Symbolic public host for node B's published DIDComm endpoint (peer-reachable name; see two-node README).
NODEB_PUBLIC_HOST=https://nodeb.aegis.local
